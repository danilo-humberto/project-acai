rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    function hasValidAvailabilityShape() {
      return request.resource.data.keys().hasAll([
          'creamFlavorIds',
          'fruitIds',
          'toppingIds',
          'syrupIds',
          'updatedAt',
          'updatedBy'
        ])
        && request.resource.data.keys().hasOnly([
          'creamFlavorIds',
          'fruitIds',
          'toppingIds',
          'syrupIds',
          'updatedAt',
          'updatedBy'
        ])
        && request.resource.data.creamFlavorIds is list
        && request.resource.data.fruitIds is list
        && request.resource.data.toppingIds is list
        && request.resource.data.syrupIds is list
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedBy == request.auth.uid
        && !request.resource.data.syrupIds.hasAny(['sem-calda']);
    }

    function orderContainsIngredientIds() {
      return request.resource.data.items.keys().hasAll([
          'iceCreamFlavorId',
          'fruitIds',
          'toppingIds',
          'syrupId'
        ])
        && request.resource.data.items.iceCreamFlavorId is string
        && request.resource.data.items.fruitIds is list
        && request.resource.data.items.toppingIds is list
        && request.resource.data.items.syrupId is string;
    }

    function selectedIngredientsAreAvailable() {
      return !exists(/databases/$(database)/documents/storeSettings/ingredientAvailability) || (
        !(request.resource.data.items.iceCreamFlavorId in get(/databases/$(database)/documents/storeSettings/ingredientAvailability).data.creamFlavorIds)
        && !request.resource.data.items.fruitIds.hasAny(get(/databases/$(database)/documents/storeSettings/ingredientAvailability).data.fruitIds)
        && !request.resource.data.items.toppingIds.hasAny(get(/databases/$(database)/documents/storeSettings/ingredientAvailability).data.toppingIds)
        && !(request.resource.data.items.syrupId in get(/databases/$(database)/documents/storeSettings/ingredientAvailability).data.syrupIds)
      );
    }

    function hasValidNewOrderShape(orderId) {
      return request.resource.data.keys().hasAll([
          'publicCode',
          'trackingCode',
          'status',
          'customer',
          'items',
          'payment',
          'total',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.trackingCode == orderId
        && request.resource.data.status == 'received'
        && request.resource.data.publicCode is string
        && request.resource.data.trackingCode is string
        && request.resource.data.customer is map
        && request.resource.data.items is map
        && request.resource.data.payment is map
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    match /admins/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list, create, update, delete: if false;
    }

    match /storeSettings/ingredientAvailability {
      allow read: if true;
      allow create, update: if isAdmin() && hasValidAvailabilityShape();
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if hasValidNewOrderShape(orderId)
        && orderContainsIngredientIds()
        && selectedIngredientsAreAvailable();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
